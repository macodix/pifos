#!/usr/bin/env python3
"""Kommandoeinstieg für den interaktiven pifos-Konfigurator.

Erzeugt Konfigurationsdateien aus Moduldeklarationen, bearbeitet bestehende
Dateien oder legt beliebige Dateien frei an.
"""

import argparse
import logging
import sys
import time

from pifos.configurator import main


def build_parser() -> argparse.ArgumentParser:
    """Baut den Argumentparser des Kommandos."""
    parser = argparse.ArgumentParser(description="Interaktiver pifos-Konfigurator.")
    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument(
        "--module",
        action="append",
        metavar="IMPORTPFAD",
        help="Modul als Importpfad (paket.modul:Klasse); mehrfach angebbar.",
    )
    mode.add_argument(
        "--edit", metavar="PFAD", help="bestehende Konfigurationsdatei bearbeiten."
    )
    mode.add_argument(
        "--free", action="store_true", help="beliebige Datei frei anlegen."
    )
    parser.add_argument(
        "--format",
        required=True,
        choices=("ini", "json", "toml"),
        help="Zielformat.",
    )
    parser.add_argument("--output", required=True, help="Zieldatei.")
    parser.add_argument(
        "--input-format",
        choices=("ini", "json", "toml"),
        help="Format der --edit-Quelle; ohne Angabe wie --format.",
    )
    parser.add_argument(
        "--overwrite",
        action="store_true",
        help="bestehende Zieldatei überschreiben.",
    )
    parser.add_argument(
        "--backup-location",
        metavar="DIR",
        help="Verzeichnis für die Sicherung; ohne Angabe das Zielverzeichnis.",
    )
    return parser


if __name__ == "__main__":
    logging.basicConfig(
        stream=sys.stderr,
        level=logging.WARNING,
        format="%(asctime)s.%(msecs)03d %(levelname)-8s %(name)s %(message)s",
        datefmt="%Y-%m-%dT%H:%M:%S",
    )
    logging.Formatter.converter = time.gmtime
    sys.exit(main(build_parser().parse_args()))
